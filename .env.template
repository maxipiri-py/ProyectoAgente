# API Key de OpenAI o de GitHub Personal Access Token (si usas GitHub Models)
OPENAI_API_KEY=tu_api_key_aqui

# Base URL (vacío para OpenAI oficial, o "https://models.inference.ai.azure.com" para GitHub Models)
OPENAI_API_BASE=

# Modelo a utilizar (por defecto gpt-4o o gpt-4o-mini)
OPENAI_MODEL=gpt-4o

# Credenciales oficiales de WhatsApp Business API (Opcional, para producción)
WHATSAPP_TOKEN=tu_token_de_acceso_temporal_o_permanente
WHATSAPP_PHONE_NUMBER_ID=tu_phone_number_id_aqui
WHATSAPP_VERIFY_TOKEN=plazadent_secret_token

